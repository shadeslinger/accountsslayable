# Accounts Slayable Environment Variables
# Copy this to .env.local and fill in values

# Site URL (used for metadata, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL=https://accountsslayable.com

# Kit (ConvertKit) — email signup integration (uses v3 API)
# Form ID: Kit → Forms → your form → Embed → copy ID from embed URL
# API key: Kit → Settings → Developer → V3 Key section (NOT the "Add new key" V4 key)
# KIT_FORM_ID=
# KIT_API_KEY=

# Debug token for /api/kit-status route (optional — route returns 404 if unset)
# KIT_DEBUG_TOKEN=

# Google Analytics (not yet active)
# NEXT_PUBLIC_GA_ID=
